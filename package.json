{
  "name": "jlstudio",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@jlstudio/web",
    "dev:builder": "turbo run dev --filter=@jlstudio/builder",
    "dev:portal": "turbo run dev --filter=@jlstudio/portal",
    "lint": "turbo run lint",
    "db:generate": "turbo run db:generate",
    "db:push": "turbo run db:push"
  },
  "devDependencies": {
    "turbo": "^2"
  },
  "packageManager": "pnpm@9.15.4",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@next/swc-darwin-arm64": "^16.1.6",
    "pixelmatch": "^7.1.0",
    "playwright": "^1.58.2",
    "pngjs": "^7.0.0"
  }
}
