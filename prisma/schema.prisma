generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Auth ──
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("admin")
  createdAt DateTime @default(now())
}

// ── CRM Core ──
model Contact {
  id             String    @id @default(cuid())
  name           String
  companyName    String?
  email          String?
  phone          String?
  address        String?
  city           String?
  postalCode     String?
  type           String    @default("particulier")
  status         String    @default("new")
  source         String?
  score          Int       @default(0)
  projectType    String?
  budget         String?
  estimatedPrice Float?
  notes          String?
  lostReason     String?
  quoteAmount    Float?
  paymentStatus  String    @default("none")
  paidAmount     Float     @default(0)
  paidAt         DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  appointments Appointment[]
  interactions Interaction[]
  documents    Document[]
  mailLogs     MailLog[]
  projects     Project[]
}

model Interaction {
  id        String   @id @default(cuid())
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  type      String
  direction String?
  subject   String?
  content   String?
  duration  Int?
  createdAt DateTime @default(now())
}

model Appointment {
  id          String   @id @default(cuid())
  contactId   String?
  contact     Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  status      String   @default("scheduled")
  location    String?
  createdAt   DateTime @default(now())
}

// ── Documents ──
model Document {
  id               String    @id @default(cuid())
  contactId        String?
  contact          Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
  projectId        String?
  project          Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  type             String
  templateSlug     String?
  fileName         String?
  filePath         String?
  documentNumber   String?
  status           String    @default("draft")
  amount           Float?
  formData         String?
  linkedDocumentId String?
  signedAt         DateTime?
  signedBy         String?
  signedPdfPath    String?
  sentAt           DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  signatures        Signature[]
  signatureRequests SignatureRequest[]
  mailLogs          MailLog[]
}

model DocumentCounter {
  id      String @id @default(cuid())
  type    String
  year    Int
  counter Int    @default(0)

  @@unique([type, year])
}

// ── Signature electronique ──
model Signature {
  id             String   @id @default(cuid())
  documentId     String
  document       Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  signerName     String
  signerEmail    String
  signatureImage String?
  signatureType  String   @default("draw")
  signedAt       DateTime @default(now())
  ipAddress      String?
  userAgent      String?
  documentHash   String?
  proofData      String?
  isValid        Boolean  @default(true)

  signatureRequest SignatureRequest?
}

model SignatureRequest {
  id             String     @id @default(cuid())
  documentId     String
  document       Document   @relation(fields: [documentId], references: [id], onDelete: Cascade)
  token          String     @unique
  recipientEmail String
  recipientName  String?
  status         String     @default("pending")
  expiresAt      DateTime
  signatureId    String?    @unique
  signature      Signature? @relation(fields: [signatureId], references: [id])
  createdAt      DateTime   @default(now())
}

// ── Emails ──
model MailLog {
  id          String    @id @default(cuid())
  contactId   String?
  contact     Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
  documentId  String?
  document    Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)
  type        String?
  subject     String?
  to          String
  cc          String?
  bcc         String?
  htmlContent String?
  textContent String?
  attachments String?
  status      String    @default("pending")
  error       String?
  sentAt      DateTime?
  createdAt   DateTime  @default(now())
}

// ── Projet Management ──
model Project {
  id              String    @id @default(cuid())
  contactId       String?
  contact         Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
  name            String
  description     String?
  status          String    @default("planification")
  priority        String    @default("medium")
  projectType     String?
  technologies    String?
  startDate       DateTime?
  endDate         DateTime?
  estimatedBudget Float?
  actualBudget    Float?
  progress        Int       @default(0)
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tasks        Task[]
  taskSections TaskSection[]
  milestones   Milestone[]
  documents    Document[]
}

model TaskSection {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  color       String?
  order       Int      @default(0)
  isCollapsed Boolean  @default(false)
  createdAt   DateTime @default(now())

  tasks Task[]
}

model Task {
  id             String       @id @default(cuid())
  projectId      String
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sectionId      String?
  section        TaskSection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  parentTaskId   String?
  title          String
  description    String?
  status         String       @default("todo")
  priority       String       @default("medium")
  startDate      DateTime?
  dueDate        DateTime?
  duration       Int?
  estimatedHours Float?
  actualHours    Float?
  kanbanColumn   String?
  tags           String?
  blockedReason  String?
  isCriticalPath Boolean      @default(false)
  order          Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  dependsOn  TaskDependency[] @relation("dependent")
  dependedBy TaskDependency[] @relation("predecessor")
}

model TaskDependency {
  id                String @id @default(cuid())
  dependentTaskId   String
  dependentTask     Task   @relation("dependent", fields: [dependentTaskId], references: [id], onDelete: Cascade)
  predecessorTaskId String
  predecessorTask   Task   @relation("predecessor", fields: [predecessorTaskId], references: [id], onDelete: Cascade)
  type              String @default("finish_to_start")
  lag               Int    @default(0)

  @@unique([dependentTaskId, predecessorTaskId])
}

model Milestone {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  date      DateTime
  status    String   @default("pending")
  color     String?
  createdAt DateTime @default(now())
}

// ── Settings ──
model CompanySettings {
  id                  String   @id @default("default")
  name                String   @default("")
  address             String   @default("")
  phone               String   @default("")
  email               String   @default("")
  siret               String   @default("")
  iban                String   @default("")
  bic                 String   @default("")
  tvaNumber           String   @default("")
  defaultPaymentTerms String   @default("30 jours")
  penaltyRate         Float    @default(3.0)
  legalForm           String   @default("")
  capital             String   @default("")
  rcsCity             String   @default("")
  representantName    String   @default("")
  representantRole    String   @default("")
  updatedAt           DateTime @updatedAt
}
