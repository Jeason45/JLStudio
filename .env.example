# ── PostgreSQL ──
POSTGRES_DB=jlstudio
POSTGRES_USER=jlstudio
POSTGRES_PASSWORD=change-me-strong-password

# ── Builder ──
AUTH_SECRET_BUILDER=change-me-builder-secret-min-32-characters
BUILDER_URL=https://builder.yourdomain.com
ANTHROPIC_API_KEY=sk-ant-...
RESEND_API_KEY=re_...

# ── Portal ──
AUTH_SECRET_PORTAL=change-me-portal-secret-min-32-characters

# ── MinIO / S3 Storage ──
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=change-me-strong-s3-secret
S3_BUCKET=media
S3_REGION=us-east-1
S3_PUBLIC_URL=https://storage.yourdomain.com
